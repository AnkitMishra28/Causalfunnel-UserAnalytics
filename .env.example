# MongoDB Connection URI
# For local development, use a local MongoDB instance:
MONGODB_URI=mongodb://localhost:27017/user-analytics
# For production, use MongoDB Atlas:
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxx.mongodb.net/user-analytics?retryWrites=true&w=majority

# Application Base URL
# Used for Socket.io client connection and tracker script requests
NEXT_PUBLIC_APP_URL=http://localhost:3000
